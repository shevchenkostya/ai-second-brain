# =============================================================================
# AI Second Brain — Production Environment Variables
# Copy this file to .env.prod and fill in all values before deploying.
# Never commit .env.prod to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Domain
# -----------------------------------------------------------------------------
DOMAIN=yourdomain.com

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=second_brain
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=second_brain

# Must match the values above — used by api and worker services
DATABASE_URL=postgresql+asyncpg://second_brain:change_me_strong_password@db:5432/second_brain

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_random_hex_string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_TOKEN_EXPIRE_HOURS=24

# -----------------------------------------------------------------------------
# Email (SMTP)
# For Gmail: enable App Password, use smtp.gmail.com:587
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@yourdomain.com
FRONTEND_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# First admin (created on startup if no admin exists)
# Leave empty to skip bootstrap
# -----------------------------------------------------------------------------
FIRST_ADMIN_EMAIL=admin@yourdomain.com
FIRST_ADMIN_PASSWORD=change_me_strong_admin_password

# -----------------------------------------------------------------------------
# LLM Provider
# Set llm_provider to: anthropic | ollama | mock
# -----------------------------------------------------------------------------
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (only needed if LLM_PROVIDER=ollama)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

# -----------------------------------------------------------------------------
# Embeddings
# Set embedding_provider to: openai | mock
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...
EMBEDDING_DIM=1536

# -----------------------------------------------------------------------------
# MCP — Google Drive
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Enable: Google Drive API
# OAuth redirect URI must be registered: https://yourdomain.com/api/mcp/google/callback
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/mcp/google/callback

# -----------------------------------------------------------------------------
# Frontend
# Must match your domain — used by Next.js to call the API
# -----------------------------------------------------------------------------
API_URL=http://api:4000
NEXT_PUBLIC_API_URL=https://yourdomain.com
