# Optional: set to enable real embeddings (default: mock)
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# LLM Provider: mock | ollama | anthropic (default: mock)
LLM_PROVIDER=ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

# Optional: Anthropic instead of Ollama
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
